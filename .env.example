# Environment Variables
# Copy this file to .env and fill in your API keys

# CoinGecko API Key (optional - free tier works without a key, but has rate limits)
# Get your API key at: https://www.coingecko.com/en/api
NUXT_PUBLIC_COINGECKO_API_KEY=

# Alpha Vantage API Key (required for stock data)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
NUXT_PUBLIC_ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY
