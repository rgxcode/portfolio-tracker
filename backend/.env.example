# Backend Environment Variables
# Copy this file to .env and fill in your values

# Azure Cosmos DB connection string (MongoDB API)
# Get this from Azure Portal → Cosmos DB → Connection strings
COSMOS_DB_CONNECTION_STRING=mongodb://localhost:27017/portfolio-tracker

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-random-secret

# Server port
PORT=4000
